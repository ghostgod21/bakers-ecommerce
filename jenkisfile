pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                scp target/bakers-ecommerce.war ubuntu@172.31.10.4:/opt/tomcat/webapps/
                '''
            }
        }
    }
}
